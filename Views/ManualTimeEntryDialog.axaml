<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TimeTracker.ViewModels"
        x:Class="TimeTracker.Views.ManualTimeEntryDialog"
        x:DataType="vm:ManualTimeEntryViewModel"
        Title="{Binding Title}"
        Width="360" Height="290"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="16" Spacing="10">
        <TextBlock Text="Date"/>
        <DatePicker SelectedDate="{Binding Date}"/>

        <Grid ColumnDefinitions="*,8,*">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Start (HH:mm)"/>
                <TextBox Text="{Binding StartTime}" PlaceholderText="09:00"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="End (HH:mm)"/>
                <TextBox Text="{Binding EndTime}" PlaceholderText="10:30"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Description"/>
        <TextBox Text="{Binding Description}" PlaceholderText="What did you work on?"/>

        <TextBlock x:Name="ErrorText"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   MinHeight="20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,6,0,0">
            <Button Content="Cancel" Click="CancelButton_Click" Width="80"/>
            <Button Content="OK"     Click="OkButton_Click"     Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>
