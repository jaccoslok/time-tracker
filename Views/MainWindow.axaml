<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TimeTracker.ViewModels"
        xmlns:models="using:TimeTracker.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="TimeTracker.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-icon.png"
        Title="TimeTracker"
        Width="960" Height="640">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="{DynamicResource AppBarBrush}" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Classes="topbar" Content="Summary" Click="SummaryButton_Click"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="topbar" Content="About" Click="AboutButton_Click"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" ColumnDefinitions="260,4,*">

            <!-- LEFT COLUMN: Projects (top) + Tasks (bottom) -->
            <Grid Grid.Column="0" RowDefinitions="*,4,*">

                <!-- Projects panel -->
                <DockPanel Grid.Row="0" Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                        <TextBlock Text="Projects" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="+ Add" Click="AddProjectButton_Click"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                        <Button Content="Edit"
                                Click="EditProjectButton_Click"
                                IsEnabled="{Binding SelectedProject, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <Button Content="Delete"
                                Click="DeleteProjectButton_Click"
                                IsEnabled="{Binding SelectedProject, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                             DoubleTapped="ProjectsList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Project">
                                <TextBlock Text="{Binding Name}" Padding="4,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- Horizontal divider between projects and tasks -->
                <Border Grid.Row="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                <!-- Tasks panel -->
                <DockPanel Grid.Row="2" Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                        <TextBlock Text="Tasks" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="+ Add"
                                Click="AddTaskButton_Click"
                                IsEnabled="{Binding SelectedProject, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                        <Button Content="Edit"
                                Click="EditTaskButton_Click"
                                IsEnabled="{Binding SelectedTask, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <Button Content="Delete"
                                Click="DeleteTaskButton_Click"
                                IsEnabled="{Binding SelectedTask, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}"
                             DoubleTapped="TasksList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ProjectTask">
                                <TextBlock Text="{Binding Name}" Padding="4,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

            </Grid>

            <!-- Vertical divider -->
            <Border Grid.Column="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

            <!-- RIGHT COLUMN: Timer + Time log -->
            <Grid Grid.Column="2" RowDefinitions="Auto,4,*">

                <!-- TIMER PANEL -->
                <Border Grid.Row="0" Padding="16,12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding TimerTaskName}"
                                   FontStyle="Italic" Opacity="0.6"/>
                        <TextBox Text="{Binding CurrentDescription}"
                                 PlaceholderText="What are you working on?"/>
                        <!-- Elapsed time display -->
                        <TextBlock Text="{Binding ElapsedTime}"
                                   FontSize="36"
                                   FontFamily="Courier New"
                                   FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="▶  Start"
                                    Command="{Binding StartTimerCommand}"
                                    Width="90"/>
                            <Button Content="■  Stop"
                                    Command="{Binding StopTimerCommand}"
                                    Width="90"/>
                            <Button Content="Manual entry"
                                    Click="ManualEntryButton_Click"
                                    IsEnabled="{Binding SelectedTask, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Horizontal divider -->
                <Border Grid.Row="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                <!-- TIME LOG -->
                <DockPanel Grid.Row="2" Margin="8">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <TextBlock Text="Time Log" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button Content="Edit"
                                    Click="EditTimeEntryButton_Click"
                                    IsEnabled="{Binding SelectedTimeEntry, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                            <Button Content="Delete"
                                    Click="DeleteTimeEntryButton_Click"
                                    IsEnabled="{Binding SelectedTimeEntry, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Column headers — widths must match the DataTemplate Grid below -->
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="110,60,60,80,*" Margin="8,0,0,2">
                        <TextBlock Grid.Column="0" Text="Date"        FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Start"       FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Stop"        FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Duration"    FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="Description" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- x:CompileBindings="False" on DataTemplate allows StringFormat -->
                    <ListBox ItemsSource="{Binding TimeEntries}"
                             SelectedItem="{Binding SelectedTimeEntry}"
                             DoubleTapped="TimeEntriesList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Grid ColumnDefinitions="110,60,60,80,*">
                                    <TextBlock Grid.Column="0" Text="{Binding StartedAtLocal, StringFormat={}{0:dd-MM-yyyy}}" Padding="0,2"/>
                                    <TextBlock Grid.Column="1" Text="{Binding StartedAtLocal, StringFormat={}{0:HH:mm}}"      Padding="0,2"/>
                                    <TextBlock Grid.Column="2" Text="{Binding StoppedAtLocal, StringFormat={}{0:HH:mm}}"      Padding="0,2"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Duration,       StringFormat={}{0:hh\\:mm}}"    Padding="0,2"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Description}"                                   Padding="0,2"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

            </Grid>

        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBrush}" Padding="12,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Foreground="{DynamicResource BarForegroundBrush}" Text="Project:"/>
                <TextBlock Foreground="{DynamicResource BarAccentBrush}" Text="{Binding SelectedProject.Name, FallbackValue='—'}"/>
                <TextBlock Foreground="{DynamicResource BarMutedBrush}" Text="|"/>
                <TextBlock Foreground="{DynamicResource BarForegroundBrush}" Text="Task:"/>
                <TextBlock Foreground="{DynamicResource BarAccentBrush}" Text="{Binding SelectedTask.Name, FallbackValue='—'}"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
